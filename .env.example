# Alpaca Paper Trading credentials
# Get from https://app.alpaca.markets → Paper Account → API Keys
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Anthropic
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-6

# Database
MAGPIE_DB_PATH=./data/magpie.duckdb

# Risk controls (as decimals: 0.10 = 10%)
MAGPIE_MAX_POSITION_PCT=0.10
MAGPIE_MAX_DAILY_LOSS_PCT=0.02
